# Application
APP_ENV=development
APP_PORT=8080
APP_NAME=CareerCopilot

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=careercopilot
DB_PASSWORD=careercopilot_secret
DB_NAME=careercopilot
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ES_ADDRESSES=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=10080

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=CareerCopilot
SMTP_FROM_EMAIL=noreply@careercopilot.io

# Frontend
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60

# Scheduler
SCHEDULER_JOB_INTERVAL_HOURS=6
SCHEDULER_DIGEST_CRON=0 7 * * *
